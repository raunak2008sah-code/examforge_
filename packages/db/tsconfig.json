{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Output to dist/ — consumers import compiled JS + declarations
    "outDir": "dist",
    "rootDir": "src",

    // Node.js package — no DOM types needed
    "lib": ["es2022"],
    "module": "commonjs",
    "moduleResolution": "node",

    // Prisma client codegen is not authored by us — skip lib check
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
