{
  "name": "@examforge/db",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, and generated client for ExamForge",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "pnpm db:generate && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:format": "prisma format",
    "db:validate": "prisma validate"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "prisma": "6.1.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@prisma/client": "6.1.0"
  }
}
