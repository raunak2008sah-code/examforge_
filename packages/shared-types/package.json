{
  "name": "@examforge/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for ExamForge — Prisma models, API contracts, parser output schema",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "types:generate": "echo 'TODO(1.3): generate from Prisma + OpenAPI'",
    "types:verify": "echo 'TODO(1.3.4): verify web/processor types match'"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "rimraf": "6.0.1",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "@examforge/db": "workspace:^",
    "zod": "^4.4.3"
  }
}
