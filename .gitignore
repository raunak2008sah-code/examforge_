# =============================================================================
# ExamForge — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
.next/
out/
.vercel/

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
.python-version

# ---------------------------------------------------------------------------
# Python tools
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Environment & secrets (NEVER commit these)
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Editor artefacts
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Prisma
# ---------------------------------------------------------------------------
# Generated client lives in node_modules — never commit it
# prisma/generated/   # uncomment if using custom output dir

# ---------------------------------------------------------------------------
# Turborepo (future)
# ---------------------------------------------------------------------------
.turbo/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
