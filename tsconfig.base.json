{
  // Shared TypeScript compiler options for all packages in the monorepo.
  // Every tsconfig.json should extend this file and override only what differs.
  "compilerOptions": {
    // --- Language & Output ---
    "target": "es2022",
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": false,
    "skipLibCheck": true,

    // --- Strictness (CLAUDE.md §2.1) ---
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // --- Developer Experience ---
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // --- Unused Code (catch dead code early) ---
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
