# Root env example (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=examforge
DATABASE_URL=postgresql://postgres:password@localhost:5432/examforge
DIRECT_URL=postgresql://postgres:password@localhost:5432/examforge

# Frontend variables
BETTER_AUTH_SECRET=local-development-secret-key-12345
BETTER_AUTH_URL=http://localhost:3000
PARSER_SERVICE_URL=http://localhost:8000
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_SERVICE_ROLE_KEY=placeholder

LOG_LEVEL=debug
NODE_ENV=development
