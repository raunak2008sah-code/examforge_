{
  "name": "examforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter @examforge/db --filter @examforge/shared-types build && pnpm --filter @examforge/web build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "postinstall": "pnpm --filter @examforge/db run db:generate"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
